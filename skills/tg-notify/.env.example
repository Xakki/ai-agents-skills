# tg-notify credentials & destination — copy to ~/.config/tg-notify/.env (chmod 600).
# These can also be exported as real environment variables (which take precedence).
# NEVER commit a filled-in copy — only this template lives in the repo.

# Bot token from @BotFather (required).
TELEGRAM_BOT_TOKEN=

# Destination (required). Pick ONE depending on where you want notifications:
#   • Private chat (DM): your numeric user id, e.g. 123456789
#   • Group / supergroup: the negative id, e.g. -1001234567890
#   • Channel: the channel id (-100…) or its public @username, e.g. @my_channel
# The bot must be a member (and admin, for channels) of the destination.
TELEGRAM_CHAT_ID=

# Forum topic id — only for supergroups with topics enabled. Leave empty otherwise.
TELEGRAM_THREAD_ID=

# Optional mention prepended to every message (e.g. @username). Empty = no mention.
TELEGRAM_MENTION=

# --- tg-report skill: per-topic report routing (optional) ---
# Override destination chat for reports (default: TELEGRAM_CHAT_ID above).
TG_REPORT_CHAT_ID=
# Forum topic for completion reports (default: TELEGRAM_THREAD_ID above).
TG_REPORT_COMPLETION_THREAD=
# Forum topic for task reports. If empty, task reports fall back to the
# completion topic — set it so they don't land in the wrong place.
TG_REPORT_TASK_THREAD=

# --- Optional overrides (usually leave unset) ---
# Where mutable state/logs live (default: $CLAUDE_PLUGIN_DATA or ~/.local/state/tg-notify):
# TG_NOTIFY_HOME=
# Alternate path to this creds file:
# TG_NOTIFY_ENV=

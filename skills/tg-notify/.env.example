# tg-notify credentials & destination — copy to ~/.config/tg-notify/.env (chmod 600).
# These can also be exported as real environment variables (which take precedence).
# NEVER commit a filled-in copy — only this template lives in the repo.

# Bot token from @BotFather (required).
TELEGRAM_BOT_TOKEN=

# Destination (required). Pick ONE depending on where you want notifications:
#   • Private chat (DM): your numeric user id, e.g. 123456789
#   • Group / supergroup: the negative id, e.g. -1001234567890
#   • Channel: the channel id (-100…) or its public @username, e.g. @my_channel
# The bot must be a member (and admin, for channels) of the destination.
TELEGRAM_CHAT_ID=

# Forum topic id — only for supergroups with topics enabled. Leave empty otherwise.
TELEGRAM_THREAD_ID=

# Optional mention prepended to every message (e.g. @username). Empty = no mention.
TELEGRAM_MENTION=

# --- tg-report skill: on-request reports to a notify group (optional) ---
# Reports go to a SEPARATE destination from the auto-notify hooks. The hooks ping
# you privately via TELEGRAM_CHAT_ID (a DM); reports go to a group with topics via
# TELEGRAM_NOTIFY_*. Do NOT reuse TELEGRAM_CHAT_ID for reports — topics need a group.
# These may also live in ~/.claude/settings.json (env block).
#
# Leave these COMMENTED here. tg-report captures them from process env
# (settings.json) first; an empty assignment in a copied .env would clobber that.
# Uncomment + fill only if you keep report routing in this file instead.
#
# Report destination: the group/supergroup id, e.g. -1001234567890.
# TELEGRAM_NOTIFY_CHAT_ID=
# Forum topic id for completion reports.
# TELEGRAM_NOTIFY_COMPLETION_THREAD=
# Forum topic id for task reports.
# TELEGRAM_NOTIFY_TASK_THREAD=

# --- Optional overrides (usually leave unset) ---
# Where mutable state/logs live (default: $CLAUDE_PLUGIN_DATA or ~/.local/state/tg-notify):
# TG_NOTIFY_HOME=
# Alternate path to this creds file:
# TG_NOTIFY_ENV=
